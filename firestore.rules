rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidChat(data) {
      return data.keys().hasAll(['title', 'userId', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 4
        && data.title is string && data.title.size() <= 200
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'userId', 'role', 'text', 'createdAt'])
        && data.chatId is string && data.chatId.size() <= 128
        && data.userId == request.auth.uid
        && (data.role == "user" || data.role == "model" || data.role == "system")
        && data.text is string && data.text.size() <= 100000
        && data.createdAt is timestamp
        && (!('groundingChunks' in data) || data.groundingChunks is list || data.groundingChunks == null)
        && (!('attachments' in data) || data.attachments is list || data.attachments == null);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create, update: if isSignedIn() 
        && userId == request.auth.uid
        && incoming().keys().hasAny(['photoURL', 'displayName', 'credits', 'freeCredits', 'lastResetDate'])
        && (!("photoURL" in incoming()) || incoming().photoURL is string || incoming().photoURL == null)
        && (!("displayName" in incoming()) || incoming().displayName is string || incoming().displayName == null)
        && (!("credits" in incoming()) || incoming().credits is number)
        && (!("freeCredits" in incoming()) || incoming().freeCredits is number)
        && (!("lastResetDate" in incoming()) || incoming().lastResetDate is string);
    }

    match /chats/{chatId} {
      allow read, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(chatId)
        && isValidChat(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt'])
        )
        && incoming().title is string && incoming().title.size() <= 200
        && incoming().updatedAt == request.time
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt;
        
      match /messages/{messageId} {
        allow read: if isSignedIn() 
          && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow list: if isSignedIn() 
          && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
          
        allow create: if isSignedIn()
          && isValidId(messageId)
          && isValidMessage(incoming())
          && incoming().chatId == chatId
          && incoming().createdAt == request.time
          && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;

        allow update: if isSignedIn()
          && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'groundingChunks', 'attachments'])
          && incoming().text is string && incoming().text.size() <= 100000
          && (!('groundingChunks' in incoming()) || incoming().groundingChunks is list || incoming().groundingChunks == null)
          && (!('attachments' in incoming()) || incoming().attachments is list || incoming().attachments == null)
          && incoming().chatId == existing().chatId
          && incoming().userId == existing().userId
          && incoming().role == existing().role
          && incoming().createdAt == existing().createdAt
          && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }
  }
}
