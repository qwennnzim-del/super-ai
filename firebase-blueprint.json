{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "photoURL": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["photoURL"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation session.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["title", "userId", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message within a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["chatId", "userId", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "User chats"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages inside a chat"
    }
  }
}
